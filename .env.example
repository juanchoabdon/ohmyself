# ohmyself! — environment template.
# Copy to .env.local and fill with real values. NEVER commit real keys.

# ── Supabase (project: ohmyself) ────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Server-only. Bypasses RLS. NEVER expose to the browser / web app.
SUPABASE_SERVICE_ROLE=YOUR_SERVICE_ROLE_KEY

# Storage bucket that holds the markdown brain (created by migration).
BRAIN_BUCKET=brain

# ── Google sign-in (Supabase Auth → Google provider) ────────────────────────
# Only needed if you run Supabase LOCALLY (referenced by supabase/config.toml).
# For the hosted project, configure these in the Dashboard instead:
#   Authentication → Providers → Google (paste Client ID + Secret),
#   and add your site URLs under Authentication → URL Configuration.
# Create credentials at https://console.cloud.google.com → OAuth client (Web),
# with redirect URI: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET

# ── Server (MCP + REST API) ─────────────────────────────────────────────────
PORT=8787
# Vault backend: "supabase" (cloud, multi-tenant) or "fs" (local folder).
VAULT_BACKEND=supabase
# Only used when VAULT_BACKEND=fs (e.g. your local Obsidian vault, gitignored).
FS_VAULT_DIR=./vault

# ── OAuth 2.1 / official connector (Claude + ChatGPT) ───────────────────────
# Public base URL of the server = OAuth issuer + MCP resource identifier.
# In single-domain prod (web rewrites /mcp,/oauth,/.well-known to the API)
# set all three to your web origin, e.g. https://www.ohmyself.ai
OMS_ISSUER=http://localhost:8787
PUBLIC_API_URL=http://localhost:8787
# Where the /authorize consent page lives (the Next.js web app).
PUBLIC_WEB_URL=http://localhost:3000
# Token lifetimes (seconds). Defaults: access 1h, refresh 30d, code 2m.
OAUTH_ACCESS_TTL_S=3600
OAUTH_REFRESH_TTL_S=2592000
OAUTH_CODE_TTL_S=120

# Token the PUBLIC website agent uses. Read-only, public-visibility notes only.
# Generate a random value; this is a capability token, not a secret identity.
PUBLIC_AGENT_TOKEN=change-me-public-readonly-token
# The user id whose public brain the public agent answers about (e.g. you).
PUBLIC_AGENT_USER_ID=YOUR_SUPABASE_USER_ID

# ── Connectors (optional) ───────────────────────────────────────────────────
# Google Calendar → transcripts connector (OAuth). Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/connectors/google/callback

# Granola transcripts connector. Users paste their own grn_ API key in the UI
# (generated in the Granola desktop app → Settings → Connectors → API keys;
# requires a Granola Business/Enterprise plan). Stored encrypted at rest.
GRANOLA_API_BASE=https://public-api.granola.ai
# 32+ char random secret used to encrypt stored connector credentials (AES-GCM).
# Generate: openssl rand -base64 48
CONNECTION_ENC_KEY=change-me-long-random-secret
# Shared secret that guards the scheduled sync endpoint (/cron/sync). On Vercel,
# set this env and Vercel automatically sends it as a Bearer token on cron hits.
CRON_SECRET=change-me-cron-secret

# ── Organizer (OpenAI) — extracts people/projects/todos from transcripts ─────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Web (Next.js) — only PUBLIC values, prefixed NEXT_PUBLIC_ ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
NEXT_PUBLIC_API_URL=http://localhost:8787
