# ohmyself! — environment template.
# Copy to .env.local and fill with real values. NEVER commit real keys.

# ── Supabase (project: ohmyself) ────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
# Server-only. Bypasses RLS. NEVER expose to the browser / web app.
SUPABASE_SERVICE_ROLE=YOUR_SERVICE_ROLE_KEY

# Storage bucket that holds the markdown brain (created by migration).
BRAIN_BUCKET=brain

# ── Server (MCP + REST API) ─────────────────────────────────────────────────
PORT=8787
# Vault backend: "supabase" (cloud, multi-tenant) or "fs" (local folder).
VAULT_BACKEND=supabase
# Only used when VAULT_BACKEND=fs (e.g. your local Obsidian vault, gitignored).
FS_VAULT_DIR=./vault

# Token the PUBLIC website agent uses. Read-only, public-visibility notes only.
# Generate a random value; this is a capability token, not a secret identity.
PUBLIC_AGENT_TOKEN=change-me-public-readonly-token
# The user id whose public brain the public agent answers about (e.g. you).
PUBLIC_AGENT_USER_ID=YOUR_SUPABASE_USER_ID

# ── Connectors (optional) ───────────────────────────────────────────────────
# Google Calendar → transcripts connector (OAuth). Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/connectors/google/callback

# ── Web (Next.js) — only PUBLIC values, prefixed NEXT_PUBLIC_ ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
NEXT_PUBLIC_API_URL=http://localhost:8787
