{
  "name": "ohmyself",
  "version": "0.1.0",
  "private": true,
  "description": "ohmyself! — your second brain as loose markdown, exposed over MCP + REST. Multi-tenant, privacy-aware.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @ohmyself/server dev",
    "dev:web": "pnpm --filter @ohmyself/web dev",
    "mcp": "pnpm --filter @ohmyself/server mcp",
    "seed": "pnpm --filter @ohmyself/server seed",
    "typecheck": "pnpm -r typecheck",
    "db:push": "supabase db push",
    "oms": "pnpm --filter @ohmyself/server exec tsx src/cli/index.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
