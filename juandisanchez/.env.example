# juandisanchez.com — environment template.
# Copy to .env.local and fill with real values. NEVER commit real keys.

# ── OpenAI (the model that powers the agent) ────────────────────────────────
# Server-side only. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional. Defaults to gpt-4o-mini (fast + cheap). Use gpt-4o for richer answers.
OPENAI_MODEL=gpt-4o-mini

# ── ohmyself! (the "second self" brain this site reads from) ────────────────
# Public base URL of the ohmyself API/MCP server.
OHMYSELF_API_URL=https://ohmyself-api.vercel.app
# A PUBLIC, read-only token (scope: public). It only ever exposes notes the
# owner explicitly marked `public`. Create one in the ohmyself web app
# (Settings → API tokens → scope: public). Server-side only — never NEXT_PUBLIC_.
OHMYSELF_PUBLIC_TOKEN=oms_...

# ── Persona (who this site is about) ────────────────────────────────────────
PERSON_NAME=Juan Diego Sánchez
PERSON_SHORT_NAME=Juan Diego
# Optional contact shown when the agent doesn't know something publicly.
PERSON_CONTACT=

# ── Rate limiting ───────────────────────────────────────────────────────────
# Per-IP limits for the in-memory limiter (fallback). Tune as you like.
RATE_LIMIT_PER_MINUTE=12
RATE_LIMIT_PER_DAY=200
# Optional Upstash Redis (recommended in production — survives across serverless
# instances). Leave blank to use the in-memory limiter only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
