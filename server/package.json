{
  "name": "@ohmyself/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ohmyself! core + MCP server + REST API + connectors",
  "exports": {
    "./core": "./src/core/index.ts"
  },
  "bin": {
    "ohmyself-mcp": "./src/mcp/stdio.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "mcp": "tsx src/mcp/stdio.ts",
    "seed": "tsx src/scripts/seed.ts",
    "backfill": "tsx src/scripts/backfill.ts",
    "backfill:embeddings": "tsx src/scripts/backfill-embeddings.ts",
    "eval:retrieval": "tsx src/scripts/eval-retrieval.ts",
    "eval:gen-corpus": "tsx src/scripts/gen-eval-corpus.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hocuspocus/server": "^2.15.2",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-list": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-table-cell": "^3.27.4",
    "@tiptap/extension-table-header": "^3.27.4",
    "@tiptap/extension-table-row": "^3.27.4",
    "@tiptap/extension-task-item": "^3.27.4",
    "@tiptap/extension-task-list": "^3.27.4",
    "@tiptap/markdown": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@tiptap/y-tiptap": "^3.0.6",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "@vercel/functions": "^3.7.5",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "ws": "^8.21.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.27",
    "zod": "^3.23.8"
  }
}
